  {
    "id": "US-002",
    "title": "Landing Page Hero Section",
    "description": "As a visitor, I want a hero section for our SaaS product landing page with a catchy headline, a subtitle describing the value proposition, a call-to-action button, and a background gradient or illustration. It should feel modern, bold, and inspiring...",
    "priority": "Medium",
    "status": "In Progress",
    "assignee": "Thomas Martin",
    "uiProposal": "<!DOCTYPE html><html lang=\"fr\"><head><meta charset=\"UTF-8\" /><meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\" /><title>Hero Section</title><style>body{margin:0;font-family:-apple-system,BlinkMacSystemFont,\"Segoe UI\",Roboto,Arial,sans-serif;background:#f8fafc;color:#0f172a;} header{min-height:100vh;display:flex;align-items:center;justify-content:center;padding:40px;box-sizing:border-box;background:linear-gradient(135deg,#f8fafc,#e5e7eb);} .container{max-width:1000px;text-align:center;} h1{font-size:40px;line-height:1.2;margin-bottom:16px;} p{font-size:18px;opacity:.9;margin-bottom:32px;} .cta{display:inline-flex;align-items:center;gap:12px;margin-bottom:60px;} .cta button{padding:14px 26px;font-size:16px;font-weight:600;border:none;border-radius:999px;cursor:pointer;transition:transform .15s,box-shadow .15s;} .primary{background:#0f172a;color:#fff;box-shadow:0 10px 30px rgba(15,23,42,.25);} .primary:hover{transform:translateY(-2px);} .secondary{background:transparent;color:#0f172a;border:1px solid rgba(15,23,42,.3);} .badge{display:inline-block;margin-bottom:20px;padding:6px 14px;border-radius:999px;background:rgba(15,23,42,.08);font-size:13px;} .features{display:grid;grid-template-columns:repeat(auto-fit,minmax(240px,1fr));gap:24px;} .feature{background:#fff;border-radius:20px;padding:28px;box-shadow:0 10px 30px rgba(0,0,0,.08);text-align:left;transition:transform .15s,box-shadow .15s;} .feature:hover{transform:translateY(-4px);box-shadow:0 16px 40px rgba(0,0,0,.12);} .feature h3{margin-top:0;margin-bottom:10px;font-size:18px;} .feature p{margin:0;font-size:15px;opacity:.85;} </style></head><body><header><div class=\"container\"><span class=\"badge\">🚀 Nouvelle génération SaaS</span><h1>Boostez votre productivité<br/>avec une plateforme tout-en-un</h1><p>Gérez vos projets, automatisez vos processus et collaborez efficacement avec une solution moderne, rapide et sécurisée.</p><div class=\"cta\"><button class=\"primary\">Démarrer gratuitement</button><button class=\"secondary\">Voir la démo</button></div><div class=\"features\"><div class=\"feature\"><h3>⚡ Performance</h3><p>Une plateforme rapide et fiable pour accompagner votre croissance sans compromis.</p></div><div class=\"feature\"><h3>🔒 Sécurité</h3><p>Vos données sont protégées avec des standards de sécurité de niveau entreprise.</p></div><div class=\"feature\"><h3>🤝 Collaboration</h3><p>Travaillez en équipe plus efficacement grâce à des outils collaboratifs intégrés.</p></div></div></div></header></body></html>"
  },
  {
    "id": "US-003",
    "title": "Contact Form",
    "description": "As a user, I want a contact form with fields for name, email, subject, and message. Include form validation, a send button with loading state, and a success message after submission. Add a map or address section next to the form.",
    "priority": "Low",
    "status": "To Do",
    "assignee": "Sophie Bernard",
    "uiProposal": "<!DOCTYPE html>\n<html lang=\"fr\">\n<head>\n  <meta charset=\"UTF-8\" />\n  <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\" />\n  <title>Contact</title>\n  <style>\n    :root {\n      --primary: #4f46e5;\n      --text: #1f2937;\n      --muted: #6b7280;\n      --bg: #f9fafb;\n      --card: #ffffff;\n      --aside-bg: #1f2937; /* gris bleuté foncé */\n      --aside-text: #e5e7eb;\n      --success: #16a34a;\n      --error: #dc2626;\n      --radius: 14px;\n    }\n    * { box-sizing: border-box; }\n    body { margin: 0; font-family: system-ui, -apple-system, BlinkMacSystemFont, \"Segoe UI\", sans-serif; background: var(--bg); color: var(--text); }\n    main { padding: 24px; display: grid; grid-template-columns: 1fr; gap: 24px; max-width: 900px; margin: 0 auto; }\n    @media (min-width: 768px) { main { grid-template-columns: 1.2fr 0.8fr; } }\n    .card { background: var(--card); border-radius: var(--radius); padding: 24px; box-shadow: 0 10px 25px rgba(0,0,0,0.05); }\n    aside.card { background: var(--aside-bg); color: var(--aside-text); }\n    aside.card strong { color: #ffffff; }\n    h1 { margin-top: 0; font-size: 1.5rem; }\n    p { color: var(--muted); margin-bottom: 24px; }\n    form { display: grid; gap: 16px; }\n    label { font-size: 0.85rem; font-weight: 500; }\n    input, textarea { width: 100%; padding: 12px 14px; border-radius: 10px; border: 1px solid #e5e7eb; font-size: 0.9rem; }\n    input:focus, textarea:focus { outline: none; border-color: var(--primary); box-shadow: 0 0 0 3px rgba(79,70,229,0.15); }\n    textarea { resize: vertical; min-height: 120px; }\n    .error { font-size: 0.75rem; color: var(--error); display: none; }\n    button { margin-top: 8px; padding: 12px 16px; border-radius: 12px; border: none; background: var(--primary); color: #fff; font-size: 0.95rem; font-weight: 600; cursor: pointer; }\n    button:hover { background: #4338ca; }\n    button:disabled { opacity: 0.7; cursor: not-allowed; }\n    .success-message { margin-top: 16px; padding: 12px 14px; border-radius: 10px; background: #dcfce7; color: var(--success); font-size: 0.85rem; display: none; }\n    .map { width: 100%; height: 220px; border-radius: var(--radius); background: linear-gradient(135deg, #374151, #111827); display: flex; align-items: center; justify-content: center; color: #ffffff; font-weight: 600; font-size: 0.9rem; margin-bottom: 16px; }\n    .address { font-size: 0.85rem; color: var(--aside-text); line-height: 1.5; }\n  </style>\n</head>\n<body>\n  <main>\n    <section class=\"card\">\n      <h1>Nous contacter</h1>\n      <p>Une question ou un besoin particulier ? Remplissez le formulaire ci-dessous et nous vous répondrons rapidement.</p>\n      <form id=\"contactForm\" novalidate>\n        <div><label for=\"name\">Nom</label><input id=\"name\" name=\"name\" type=\"text\" required /><div class=\"error\">Veuillez renseigner votre nom.</div></div>\n        <div><label for=\"email\">Email</label><input id=\"email\" name=\"email\" type=\"email\" required /><div class=\"error\">Adresse email invalide.</div></div>\n        <div><label for=\"subject\">Sujet</label><input id=\"subject\" name=\"subject\" type=\"text\" required /><div class=\"error\">Veuillez indiquer un sujet.</div></div>\n        <div><label for=\"message\">Message</label><textarea id=\"message\" name=\"message\" required></textarea><div class=\"error\">Le message ne peut pas être vide.</div></div>\n        <button type=\"submit\" id=\"submitBtn\">Envoyer le message</button>\n        <div class=\"success-message\" id=\"successMessage\">✅ Votre message a bien été envoyé.</div>\n      </form>\n    </section>\n    <aside class=\"card\">\n      <div class=\"map\">Carte / Localisation</div>\n      <div class=\"address\"><strong>Notre adresse</strong><br />12 rue de l'Innovation<br />75000 Paris<br />France</div>\n    </aside>\n  </main>\n  <script>\n    const form = document.getElementById('contactForm');\n    const submitBtn = document.getElementById('submitBtn');\n    const successMessage = document.getElementById('successMessage');\n    form.addEventListener('submit', (e) => {\n      e.preventDefault(); let valid = true;\n      [...form.elements].forEach(el => {\n        if (el.tagName === 'INPUT' || el.tagName === 'TEXTAREA') {\n          const error = el.nextElementSibling;\n          if (!el.checkValidity()) { error.style.display = 'block'; valid = false; }\n          else { error.style.display = 'none'; }\n        }\n      });\n      if (!valid) return;\n      submitBtn.disabled = true; submitBtn.textContent = 'Envoi en cours...';\n      setTimeout(() => { submitBtn.disabled = false; submitBtn.textContent = 'Envoyer le message'; successMessage.style.display = 'block'; form.reset(); }, 1200);\n    });\n  </script>\n</body>\n</html>"
  }
]