    "uiProposal": "<!DOCTYPE html><html lang=\"fr\"><head><meta charset=\"UTF-8\" /><meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\" /><title>Hero Section</title><style>body{margin:0;font-family:-apple-system,BlinkMacSystemFont,\"Segoe UI\",Roboto,Arial,sans-serif;background:#0f172a;color:#fff;} header{min-height:100vh;display:flex;align-items:center;justify-content:center;padding:40px;box-sizing:border-box;background:linear-gradient(135deg,#6366f1,#22d3ee);} .container{max-width:900px;text-align:center;} h1{font-size:40px;line-height:1.2;margin-bottom:16px;} p{font-size:18px;opacity:.9;margin-bottom:32px;} .cta{display:inline-flex;align-items:center;gap:12px;} .cta button{padding:14px 26px;font-size:16px;font-weight:600;border:none;border-radius:999px;cursor:pointer;transition:transform .15s,box-shadow .15s;} .primary{background:#fff;color:#0f172a;box-shadow:0 10px 30px rgba(0,0,0,.25);} .primary:hover{transform:translateY(-2px);} .secondary{background:transparent;color:#fff;border:1px solid rgba(255,255,255,.5);} .badge{display:inline-block;margin-bottom:20px;padding:6px 14px;border-radius:999px;background:rgba(255,255,255,.2);font-size:13px;} .illustration{margin-top:50px;background:rgba(255,255,255,.15);border-radius:20px;height:220px;display:flex;align-items:center;justify-content:center;font-size:14px;opacity:.8;} </style></head><body><header><div class=\"container\"><span class=\"badge\">🚀 Nouvelle génération SaaS</span><h1>Boostez votre productivité<br/>avec une plateforme tout-en-un</h1><p>Gérez vos projets, automatisez vos processus et collaborez efficacement avec une solution moderne, rapide et sécurisée.</p><div class=\"cta\"><button class=\"primary\">Démarrer gratuitement</button><button class=\"secondary\">Voir la démo</button></div><div class=\"illustration\">Illustration / visuel produit</div></div></header></body></html>"
