  {
    "id": "US-002",
    "title": "Landing Page Hero Section",
    "description": "As a visitor, I want a hero section for our SaaS product landing page with a catchy headline, a subtitle describing the value proposition, a call-to-action button, and a background gradient or illustration. It should feel modern, bold, and inspiring.",
    "priority": "Medium",
    "status": "To Do",
    "assignee": "Thomas Martin",
    "uiProposal": "<!DOCTYPE html><html lang=\"fr\"><head><meta charset=\"UTF-8\" /><meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\" /><title>Landing Page – Hero</title><style>body{margin:0;font-family:-apple-system,BlinkMacSystemFont,\"Segoe UI\",Roboto,Arial,sans-serif;background:#0f172a;color:#fff}header{min-height:100vh;display:flex;align-items:center;justify-content:center;padding:32px} .hero{max-width:420px;text-align:left} .badge{display:inline-block;padding:6px 12px;border-radius:999px;background:rgba(255,255,255,0.1);font-size:12px;margin-bottom:16px} h1{font-size:36px;line-height:1.2;margin:0 0 16px} p{font-size:16px;line-height:1.6;color:#cbd5e1;margin-bottom:24px} .cta{display:inline-flex;align-items:center;justify-content:center;padding:14px 24px;border-radius:12px;background:linear-gradient(135deg,#6366f1,#22d3ee);color:#0f172a;font-weight:600;text-decoration:none;transition:transform .2s,box-shadow .2s} .cta:hover{transform:translateY(-2px);box-shadow:0 10px 30px rgba(34,211,238,.35)} .bg{position:fixed;inset:0;z-index:-1;background:radial-gradient(800px circle at 20% 20%,rgba(99,102,241,.35),transparent 40%),radial-gradient(600px circle at 80% 60%,rgba(34,211,238,.25),transparent 40%)} @media(max-width:480px){h1{font-size:30px}}</style></head><body><div class=\"bg\"></div><header><section class=\"hero\"><span class=\"badge\">Nouveau · SaaS Platform</span><h1>Boostez votre productivité avec une solution tout‑en‑un</h1><p>Centralisez vos outils, accélérez vos workflows et prenez de meilleures décisions grâce à notre plateforme SaaS moderne et performante.</p><a href=\"#\" class=\"cta\">Démarrer gratuitement</a></section></header></body></html>"
  },
  {
    "id": "US-003",
    "title": "Contact Form",
    "description": "As a user, I want a contact form with fields for name, email, subject, and message. Include form validation, a send button with loading state, and a success message after submission. Add a map or address section next to the form.",
    "priority": "Low",
    "status": "To Do",
    "assignee": "Sophie Bernard",
    "uiProposal": "<!DOCTYPE html>\n<html lang=\"fr\">\n<head>\n  <meta charset=\"UTF-8\" />\n  <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\" />\n  <title>Contact</title>\n  <style>\n    * { box-sizing: border-box; }\n    body {\n      margin: 0;\n      font-family: -apple-system, BlinkMacSystemFont, \"Segoe UI\", Roboto, Helvetica, Arial, sans-serif;\n      background: linear-gradient(135deg, #f5f7fa, #e4e9f0);\n      color: #333;\n    }\n    main {\n      padding: 24px;\n      max-width: 960px;\n      margin: 0 auto;\n    }\n    h1 {\n      text-align: center;\n      margin-bottom: 24px;\n    }\n    .container {\n      display: grid;\n      grid-template-columns: 1fr 1fr;\n      gap: 24px;\n    }\n    @media (max-width: 768px) {\n      .container { grid-template-columns: 1fr; }\n    }\n    .card {\n      background: #fff;\n      border-radius: 12px;\n      padding: 24px;\n      box-shadow: 0 10px 25px rgba(0,0,0,0.08);\n    }\n    label {\n      display: block;\n      font-weight: 600;\n      margin-bottom: 6px;\n    }\n    input, textarea {\n      width: 100%;\n      padding: 12px;\n      border-radius: 8px;\n      border: 1px solid #ccc;\n      margin-bottom: 16px;\n      font-size: 14px;\n    }\n    input:focus, textarea:focus {\n      outline: none;\n      border-color: #5b7cfa;\n      box-shadow: 0 0 0 2px rgba(91,124,250,0.2);\n    }\n    .error {\n      color: #d64545;\n      font-size: 12px;\n      margin-top: -12px;\n      margin-bottom: 12px;\n      display: none;\n    }\n    button {\n      width: 100%;\n      padding: 14px;\n      background: #5b7cfa;\n      color: #fff;\n      border: none;\n      border-radius: 10px;\n      font-size: 16px;\n      font-weight: 600;\n      cursor: pointer;\n      transition: background 0.3s, transform 0.1s;\n    }\n    button:hover { background: #4a69e0; }\n    button:active { transform: scale(0.98); }\n    button:disabled {\n      background: #9aaaf5;\n      cursor: not-allowed;\n    }\n    .success {\n      display: none;\n      margin-top: 16px;\n      padding: 12px;\n      background: #e6f7ec;\n      color: #2f8f5b;\n      border-radius: 8px;\n      text-align: center;\n      font-weight: 600;\n    }\n    .map {\n      height: 100%;\n      min-height: 320px;\n      border-radius: 12px;\n      background: linear-gradient(135deg, #dfe7ff, #c7d2fe);\n      display: flex;\n      align-items: center;\n      justify-content: center;\n      text-align: center;\n      padding: 24px;\n      color: #334;\n    }\n    .map h3 { margin-bottom: 8px; }\n    .address {\n      margin-top: 12px;\n      font-size: 14px;\n      line-height: 1.6;\n    }\n  </style>\n</head>\n<body>\n  <main>\n    <h1>Contactez-nous</h1>\n    <div class=\"container\">\n      <div class=\"card\">\n        <form id=\"contactForm\" novalidate>\n          <label for=\"name\">Nom</label>\n          <input type=\"text\" id=\"name\" required />\n          <div class=\"error\" id=\"error-name\">Le nom est requis</div>\n\n          <label for=\"email\">Email</label>\n          <input type=\"email\" id=\"email\" required />\n          <div class=\"error\" id=\"error-email\">Email invalide</div>\n\n          <label for=\"subject\">Sujet</label>\n          <input type=\"text\" id=\"subject\" required />\n          <div class=\"error\" id=\"error-subject\">Le sujet est requis</div>\n\n          <label for=\"message\">Message</label>\n          <textarea id=\"message\" rows=\"5\" required></textarea>\n          <div class=\"error\" id=\"error-message\">Le message est requis</div>\n\n          <button type=\"submit\" id=\"submitBtn\">Envoyer</button>\n          <div class=\"success\" id=\"successMsg\">✅ Message envoyé avec succès</div>\n        </form>\n      </div>\n      <div class=\"map\">\n        <div>\n          <h3>Notre adresse</h3>\n          <p>Nous sommes ravis de vous accueillir</p>\n          <div class=\"address\">\n            123 Rue de l'Innovation<br />\n            75000 Paris<br />\n            France\n          </div>\n        </div>\n      </div>\n    </div>\n  </main>\n\n  <script>\n    const form = document.getElementById('contactForm');\n    const submitBtn = document.getElementById('submitBtn');\n    const successMsg = document.getElementById('successMsg');\n\n    form.addEventListener('submit', (e) => {\n      e.preventDefault();\n      let valid = true;\n\n      const fields = ['name','email','subject','message'];\n      fields.forEach(id => {\n        const input = document.getElementById(id);\n        const error = document.getElementById('error-' + id);\n        if (!input.value || (id === 'email' && !input.value.includes('@'))) {\n          error.style.display = 'block';\n          valid = false;\n        } else {\n          error.style.display = 'none';\n        }\n      });\n\n      if (!valid) return;\n\n      submitBtn.disabled = true;\n      submitBtn.textContent = 'Envoi...';\n\n      setTimeout(() => {\n        submitBtn.disabled = false;\n        submitBtn.textContent = 'Envoyer';\n        successMsg.style.display = 'block';\n        form.reset();\n      }, 1200);\n    });\n  </script>\n</body>\n</html>"
  }
]