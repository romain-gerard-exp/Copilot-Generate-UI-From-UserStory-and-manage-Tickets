[
  {
    "id": "US-001",
    "title": "Login Page",
    "description": "As a user, I want a login page with email and password fields, a 'Remember me' checkbox, a 'Forgot password?' link, and a submit button. The page should have a modern and clean design with form validation..",
    "priority": "High",
    "status": "In Progress",
    "assignee": "Marie Dupont",
    "uiProposal": "<!DOCTYPE html>\n<html lang=\"fr\">\n<head>\n  <meta charset=\"UTF-8\" />\n  <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\" />\n  <title>Login</title>\n  <style>\n    :root{\n      --bg:#0f172a;           /* slate-900 */\n      --card:#111827;         /* gray-900 */\n      --muted:#94a3b8;        /* slate-400 */\n      --text:#e5e7eb;         /* gray-200 */\n      --primary:#6366f1;      /* indigo-500 */\n      --primary-600:#4f46e5;\n      --danger:#ef4444;\n      --success:#22c55e;\n      --radius:14px;\n      --shadow:0 20px 40px rgba(0,0,0,.35);\n    }\n    *{box-sizing:border-box}\n    html,body{height:100%}\n    body{\n      margin:0;\n      font-family: system-ui, -apple-system, Segoe UI, Roboto, Ubuntu, Cantarell, Noto Sans, Arial, \"Apple Color Emoji\", \"Segoe UI Emoji\";\n      color:var(--text);\n      background: radial-gradient(1200px 600px at 10% -10%, #1f2937 0%, transparent 60%),\n                  radial-gradient(800px 400px at 110% 10%, #1e1b4b 0%, transparent 55%),\n                  linear-gradient(180deg, #020617, var(--bg));\n      display:grid; place-items:center;\n    }\n    .container{\n      width:100%; max-width:460px; padding:24px;\n    }\n    .card{\n      background: linear-gradient(180deg, rgba(255,255,255,.04), rgba(255,255,255,0));\n      backdrop-filter: blur(6px);\n      border:1px solid rgba(255,255,255,.08);\n      border-radius:var(--radius);\n      box-shadow:var(--shadow);\n      padding:28px;\n    }\n    .brand{\n      display:flex; align-items:center; gap:12px; margin-bottom:18px;\n    }\n    .logo{\n      width:42px; height:42px; border-radius:12px;\n      background: linear-gradient(135deg, var(--primary), #22d3ee);\n      display:grid; place-items:center; color:white; font-weight:800;\n    }\n    h1{font-size:1.35rem; margin:0}\n    p.subtitle{margin:.25rem 0 1.25rem; color:var(--muted)}\n    form{display:grid; gap:14px}\n    label{font-size:.85rem; color:#c7d2fe}\n    .field{display:grid; gap:6px}\n    input[type=\"email\"], input[type=\"password\"]{\n      background:#020617;\n      color:var(--text);\n      border:1px solid rgba(255,255,255,.1);\n      border-radius:12px;\n      padding:12px 14px;\n      outline:none;\n      transition:border .2s, box-shadow .2s, transform .05s;\n    }\n    input::placeholder{color:#64748b}\n    input:focus{border-color:var(--primary); box-shadow:0 0 0 3px rgba(99,102,241,.25)}\n    .row{display:flex; justify-content:space-between; align-items:center; gap:10px}\n    .checkbox{display:flex; align-items:center; gap:8px; color:var(--muted); font-size:.85rem}\n    .checkbox input{accent-color:var(--primary)}\n    a{color:#a5b4fc; text-decoration:none}\n    a:hover{text-decoration:underline}\n    .error{color:var(--danger); font-size:.8rem; min-height:1em}\n    .actions{margin-top:6px}\n    button{\n      width:100%;\n      border:none; border-radius:12px;\n      padding:12px 16px;\n      font-weight:600; color:white;\n      background: linear-gradient(135deg, var(--primary), #22d3ee);\n      cursor:pointer;\n      transition:transform .05s, filter .2s, box-shadow .2s, opacity .2s;\n      box-shadow:0 10px 20px rgba(99,102,241,.35);\n    }\n    button:hover{filter:brightness(1.05)}\n    button:active{transform:translateY(1px)}\n    button:disabled{opacity:.6; cursor:not-allowed}\n    .loading{\n      position:relative;\n    }\n    .loading::after{\n      content:\"\";\n      position:absolute; inset:0;\n      border-radius:12px;\n      background: linear-gradient(90deg, rgba(255,255,255,0), rgba(255,255,255,.25), rgba(255,255,255,0));\n      animation: shimmer 1.2s infinite;\n    }\n    @keyframes shimmer{from{transform:translateX(-100%)} to{transform:translateX(100%)}}\n    .success{color:var(--success); font-size:.9rem; margin-top:8px}\n    footer{margin-top:14px; text-align:center; color:var(--muted); font-size:.75rem}\n  </style>\n</head>\n<body>\n  <main class=\"container\">\n    <section class=\"card\">\n      <div class=\"brand\">\n        <div class=\"logo\">A</div>\n        <div>\n          <h1>Connexion</h1>\n          <p class=\"subtitle\">Accédez à votre espace en toute sécurité</p>\n        </div>\n      </div>\n      <form id=\"loginForm\" novalidate>\n        <div class=\"field\">\n          <label for=\"email\">Email</label>\n          <input id=\"email\" type=\"email\" placeholder=\"prenom.nom@exemple.com\" required />\n          <div class=\"error\" id=\"emailError\"></div>\n        </div>\n        <div class=\"field\">\n          <label for=\"password\">Mot de passe</label>\n          <input id=\"password\" type=\"password\" placeholder=\"••••••••\" minlength=\"6\" required />\n          <div class=\"error\" id=\"passwordError\"></div>\n        </div>\n        <div class=\"row\">\n          <label class=\"checkbox\">\n            <input type=\"checkbox\" id=\"remember\" /> Se souvenir de moi\n          </label>\n          <a href=\"#\" aria-label=\"Mot de passe oublié\">Mot de passe oublié ?</a>\n        </div>\n        <div class=\"actions\">\n          <button id=\"submitBtn\" type=\"submit\" disabled>Se connecter</button>\n          <div class=\"success\" id=\"successMsg\"></div>\n        </div>\n      </form>\n    </section>\n    <footer>© 2026 — Sécurité & confidentialité</footer>\n  </main>\n\n  <script>\n    const email = document.getElementById('email');\n    const password = document.getElementById('password');\n    const submitBtn = document.getElementById('submitBtn');\n    const form = document.getElementById('loginForm');\n    const emailError = document.getElementById('emailError');\n    const passwordError = document.getElementById('passwordError');\n    const successMsg = document.getElementById('successMsg');\n\n    function validate(){\n      let ok = true;\n      emailError.textContent = '';\n      passwordError.textContent = '';\n\n      if(!email.value || !email.value.includes('@')){\n        emailError.textContent = 'Veuillez saisir un email valide.';\n        ok = false;\n      }\n      if(!password.value || password.value.length < 6){\n        passwordError.textContent = 'Le mot de passe doit contenir au moins 6 caractères.';\n        ok = false;\n      }\n      submitBtn.disabled = !ok;\n      return ok;\n    }\n\n    email.addEventListener('input', validate);\n    password.addEventListener('input', validate);\n\n    form.addEventListener('submit', (e)=>{\n      e.preventDefault();\n      if(!validate()) return;\n      submitBtn.disabled = true;\n      submitBtn.classList.add('loading');\n      successMsg.textContent = '';\n      setTimeout(()=>{\n        submitBtn.classList.remove('loading');\n        successMsg.textContent = 'Connexion réussie !';\n        submitBtn.disabled = false;\n      }, 1200);\n    });\n  </script>\n</body>\n</html>"
  },
  {
    "id": "US-002",
    "title": "Landing Page Hero Section",
    "description": "As a visitor, I want a hero section for our SaaS product landing page with a catchy headline, a subtitle describing the value proposition, a call-to-action button, and a background gradient or illustration. It should feel modern, bold, and inspiring.",
    "priority": "Medium",
    "status": "To Do",
    "assignee": "Thomas Martin",
    "uiProposal": "<!DOCTYPE html>\n<html lang=\"fr\">\n<head>\n  <meta charset=\"UTF-8\" />\n  <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\" />\n  <title>Landing Page – Hero Section</title>\n  <style>\n    * { box-sizing: border-box; margin: 0; padding: 0; }\n    body {\n      font-family: system-ui, -apple-system, BlinkMacSystemFont, \"Segoe UI\", sans-serif;\n      background: #ffffff;\n      color: #0f172a;\n    }\n\n    /* Bandeau haut */\n    .topbar {\n      position: sticky;\n      top: 0;\n      z-index: 10;\n      background: #ffffff;\n      border-bottom: 1px solid #e5e7eb;\n    }\n    .topbar-container {\n      max-width: 1100px;\n      margin: 0 auto;\n      padding: 1rem 1.5rem;\n      display: flex;\n      align-items: center;\n      justify-content: space-between;\n    }\n    .logo {\n      font-weight: 700;\n      font-size: 1.1rem;\n      letter-spacing: 0.02em;\n    }\n    .nav a {\n      margin-left: 1.25rem;\n      text-decoration: none;\n      font-size: 0.9rem;\n      color: #334155;\n    }\n    .nav a:hover { color: #6366f1; }\n\n    /* Hero */\n    header.hero {\n      padding: 4rem 1.5rem 5rem;\n      background: #ffffff;\n    }\n    .hero-container {\n      max-width: 1100px;\n      margin: 0 auto;\n      text-align: center;\n    }\n    .hero-badge {\n      display: inline-block;\n      background: #eef2ff;\n      color: #4338ca;\n      padding: 0.35rem 0.75rem;\n      border-radius: 999px;\n      font-size: 0.75rem;\n      margin-bottom: 1rem;\n      letter-spacing: 0.04em;\n    }\n    h1 {\n      font-size: 2.2rem;\n      line-height: 1.2;\n      margin-bottom: 1rem;\n      font-weight: 700;\n    }\n    p.subtitle {\n      font-size: 1.05rem;\n      color: #475569;\n      margin-bottom: 2.5rem;\n      max-width: 680px;\n      margin-left: auto;\n      margin-right: auto;\n    }\n    .cta {\n      display: inline-flex;\n      align-items: center;\n      justify-content: center;\n      padding: 0.9rem 1.6rem;\n      font-size: 1rem;\n      font-weight: 600;\n      border-radius: 0.75rem;\n      background: linear-gradient(135deg, #6366f1, #4f46e5);\n      color: #ffffff;\n      text-decoration: none;\n      transition: transform 0.2s ease, box-shadow 0.2s ease;\n      box-shadow: 0 10px 25px rgba(79,70,229,0.25);\n    }\n    .cta:hover {\n      transform: translateY(-2px);\n      box-shadow: 0 15px 35px rgba(79,70,229,0.35);\n    }\n\n    /* 3 blocs */\n    .hero-blocks {\n      margin-top: 4rem;\n      display: grid;\n      grid-template-columns: 1fr;\n      gap: 1.5rem;\n    }\n    .block {\n      border: 1px solid #e5e7eb;\n      border-radius: 1rem;\n      padding: 1.75rem;\n      text-align: left;\n      transition: transform 0.2s ease, box-shadow 0.2s ease;\n      background: #ffffff;\n    }\n    .block:hover {\n      transform: translateY(-4px);\n      box-shadow: 0 12px 30px rgba(15,23,42,0.08);\n    }\n    .block h3 {\n      font-size: 1.1rem;\n      margin-bottom: 0.5rem;\n    }\n    .block p {\n      font-size: 0.95rem;\n      color: #475569;\n      line-height: 1.5;\n    }\n\n    @media (min-width: 768px) {\n      h1 { font-size: 2.75rem; }\n      .hero-blocks {\n        grid-template-columns: repeat(3, 1fr);\n      }\n    }\n  </style>\n</head>\n<body>\n  <div class=\"topbar\">\n    <div class=\"topbar-container\">\n      <div class=\"logo\">SaaS Platform</div>\n      <nav class=\"nav\">\n        <a href=\"#\">Produit</a>\n        <a href=\"#\">Fonctionnalités</a>\n        <a href=\"#\">Tarifs</a>\n        <a href=\"#\">Contact</a>\n      </nav>\n    </div>\n  </div>\n\n  <header class=\"hero\">\n    <div class=\"hero-container\">\n      <span class=\"hero-badge\">Nouveau • SaaS Platform</span>\n      <h1>Boostez vos performances avec une plateforme pensée pour la croissance</h1>\n      <p class=\"subtitle\">\n        Centralisez vos données, automatisez vos processus et prenez de meilleures décisions,\n        plus rapidement.\n      </p>\n      <a href=\"#\" class=\"cta\">Démarrer gratuitement</a>\n\n      <div class=\"hero-blocks\">\n        <div class=\"block\">\n          <h3>Centralisation</h3>\n          <p>Regroupez toutes vos données et outils au même endroit pour une vision claire et partagée.</p>\n        </div>\n        <div class=\"block\">\n          <h3>Automatisation</h3>\n          <p>Gagnez du temps grâce à des workflows intelligents et des processus automatisés.</p>\n        </div>\n        <div class=\"block\">\n          <h3>Pilotage</h3>\n          <p>Prenez de meilleures décisions avec des indicateurs clés et des tableaux de bord clairs.</p>\n        </div>\n      </div>\n    </div>\n  </header>\n</body>\n</html>"
  },
  {
    "id": "US-003",
    "title": "Contact Form",
    "description": "As a user, I want a contact form with fields for name, email, subject, and message. Include form validation, a send button with loading state, and a success message after submission. Add a map or address section next to the form.",
    "priority": "Low",
    "status": "To Do",
    "assignee": "Sophie Bernard",
    "uiProposal": "<!DOCTYPE html>\n<html lang=\"fr\">\n<head>\n  <meta charset=\"UTF-8\" />\n  <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\" />\n  <title>Contact</title>\n  <style>\n    * { box-sizing: border-box; margin: 0; padding: 0; }\n    body {\n      font-family: system-ui, -apple-system, BlinkMacSystemFont, \"Segoe UI\", sans-serif;\n      background: #f8fafc;\n      color: #0f172a;\n    }\n\n    main {\n      max-width: 1100px;\n      margin: 0 auto;\n      padding: 3rem 1.5rem;\n    }\n\n    h1 {\n      font-size: 2rem;\n      margin-bottom: 0.75rem;\n      text-align: center;\n    }\n\n    .subtitle {\n      text-align: center;\n      color: #475569;\n      margin-bottom: 3rem;\n    }\n\n    .contact-layout {\n      display: grid;\n      grid-template-columns: 1fr;\n      gap: 2rem;\n    }\n\n    .card {\n      background: #ffffff;\n      border-radius: 1rem;\n      padding: 2rem;\n      box-shadow: 0 10px 30px rgba(15, 23, 42, 0.08);\n    }\n\n    form .field {\n      margin-bottom: 1.25rem;\n    }\n\n    label {\n      display: block;\n      font-size: 0.85rem;\n      font-weight: 600;\n      margin-bottom: 0.35rem;\n    }\n\n    input, textarea {\n      width: 100%;\n      padding: 0.65rem 0.75rem;\n      border-radius: 0.5rem;\n      border: 1px solid #cbd5f5;\n      font-size: 0.95rem;\n    }\n\n    textarea {\n      resize: vertical;\n      min-height: 120px;\n    }\n\n    input:focus, textarea:focus {\n      outline: none;\n      border-color: #6366f1;\n      box-shadow: 0 0 0 3px rgba(99,102,241,0.15);\n    }\n\n    .error {\n      color: #dc2626;\n      font-size: 0.75rem;\n      margin-top: 0.25rem;\n    }\n\n    button {\n      margin-top: 0.75rem;\n      width: 100%;\n      padding: 0.8rem;\n      border-radius: 0.75rem;\n      border: none;\n      font-size: 1rem;\n      font-weight: 600;\n      color: #ffffff;\n      background: linear-gradient(135deg, #6366f1, #4f46e5);\n      cursor: pointer;\n      transition: opacity 0.2s ease, transform 0.2s ease;\n    }\n\n    button:hover { transform: translateY(-1px); }\n    button:disabled { opacity: 0.6; cursor: not-allowed; }\n\n    .success {\n      display: none;\n      margin-top: 1rem;\n      padding: 0.75rem;\n      border-radius: 0.5rem;\n      background: #ecfeff;\n      color: #0369a1;\n      font-size: 0.9rem;\n      text-align: center;\n    }\n\n    .info h3 {\n      font-size: 1.1rem;\n      margin-bottom: 0.75rem;\n    }\n\n    .info p {\n      font-size: 0.9rem;\n      color: #475569;\n      line-height: 1.5;\n      margin-bottom: 0.75rem;\n    }\n\n    .map {\n      margin-top: 1rem;\n      border-radius: 0.75rem;\n      overflow: hidden;\n      background: #e5e7eb;\n      height: 220px;\n      display: flex;\n      align-items: center;\n      justify-content: center;\n      color: #475569;\n      font-size: 0.9rem;\n    }\n\n    @media (min-width: 768px) {\n      .contact-layout {\n        grid-template-columns: 1.2fr 0.8fr;\n      }\n    }\n  </style>\n</head>\n<body>\n  <main>\n    <h1>Nous contacter</h1>\n    <p class=\"subtitle\">Une question, un projet ou besoin d'informations ? Écrivez-nous.</p>\n\n    <div class=\"contact-layout\">\n      <div class=\"card\">\n        <form id=\"contactForm\" novalidate>\n          <div class=\"field\">\n            <label for=\"name\">Nom</label>\n            <input type=\"text\" id=\"name\" required />\n            <div class=\"error\"></div>\n          </div>\n\n          <div class=\"field\">\n            <label for=\"email\">Email</label>\n            <input type=\"email\" id=\"email\" required />\n            <div class=\"error\"></div>\n          </div>\n\n          <div class=\"field\">\n            <label for=\"subject\">Sujet</label>\n            <input type=\"text\" id=\"subject\" required />\n            <div class=\"error\"></div>\n          </div>\n\n          <div class=\"field\">\n            <label for=\"message\">Message</label>\n            <textarea id=\"message\" required></textarea>\n            <div class=\"error\"></div>\n          </div>\n\n          <button type=\"submit\">Envoyer le message</button>\n          <div class=\"success\">✅ Message envoyé avec succès. Nous vous répondrons rapidement.</div>\n        </form>\n      </div>\n\n      <div class=\"card info\">\n        <h3>Coordonnées</h3>\n        <p><strong>Adresse :</strong><br>123 Avenue de la Tech<br>75000 Paris</p>\n        <p><strong>Email :</strong> contact@exemple.com<br><strong>Téléphone :</strong> +33 1 23 45 67 89</p>\n        <div class=\"map\">Carte / Localisation</div>\n      </div>\n    </div>\n  </main>\n\n  <script>\n    const form = document.getElementById('contactForm');\n    const button = form.querySelector('button');\n    const success = form.querySelector('.success');\n\n    form.addEventListener('submit', (e) => {\n      e.preventDefault();\n      let valid = true;\n\n      form.querySelectorAll('.field').forEach(field => {\n        const input = field.querySelector('input, textarea');\n        const error = field.querySelector('.error');\n        if (!input.value.trim()) {\n          error.textContent = 'Ce champ est requis';\n          valid = false;\n        } else {\n          error.textContent = '';\n        }\n      });\n\n      if (!valid) return;\n\n      button.disabled = true;\n      button.textContent = 'Envoi en cours…';\n\n      setTimeout(() => {\n        button.disabled = false;\n        button.textContent = 'Envoyer le message';\n        success.style.display = 'block';\n        form.reset();\n      }, 1200);\n    });\n  </script>\n</body>\n</html>"
  }
]